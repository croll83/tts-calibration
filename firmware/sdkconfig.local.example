# =============================================================================
# TTS Calibration - Local Configuration (NON committare!)
# =============================================================================
# Copia questo file in sdkconfig.local e personalizza i valori.
# build.sh applica automaticamente questi valori sopra sdkconfig.
# =============================================================================

# WiFi
CONFIG_WIFI_SSID="YOUR_WIFI_SSID"
CONFIG_WIFI_PASSWORD="YOUR_WIFI_PASSWORD"

# Calibration server (IP dell'LXC su Proxmox)
CONFIG_JARVIS_SERVER_HOST="192.168.1.30"
CONFIG_JARVIS_SERVER_PORT=8200

# WebSocket URL override (lascia vuoto per usare HOST:PORT/ws/audio)
CONFIG_JARVIS_WS_URL=""

# API Token (non necessario per calibrazione)
CONFIG_JARVIS_API_TOKEN=""

# Wake word locale disabilitato (calibrazione usa streaming continuo)
# CONFIG_USE_LOCAL_WAKEWORD non va settato (default: n)
